# Cribl APM — local environment
#
# Copy to .env and fill in values. .env is gitignored.

# ---- Cribl Cloud workspace (used by scripts/deploy.mjs + Playwright tests) ----
CRIBL_BASE_URL=https://your-workspace.cribl-staging.cloud/
CRIBL_CLIENT_ID=
CRIBL_CLIENT_SECRET=

# ---- Playwright tests (tests/auth.setup.ts) ----
# Used by the auth setup fixture to log in to Cribl Cloud via Auth0 and
# cache browser state to playwright/.auth/cribl-cloud.json.
CRIBL_TEST_EMAIL=
CRIBL_TEST_PASSWORD=
# Optional: override the path the pack UI is mounted at inside the workspace.
# Defaults to /app-ui/apm/ which matches the Cribl App Platform convention.
# CRIBL_APM_APP_PATH=/app-ui/apm/

# ---- flagd-ui (used by scripts/flagd-set.sh, once rewritten to HTTP API) ----
# Point at the flagd-ui service in the demo cluster (port-forward or ingress).
# FLAGD_UI_URL=http://localhost:4000

# ---- Cribl MCP Server (scripts/cribl-mcp.sh) ----
# Optional: require an API key on requests to the local MCP server. Leave
# blank for unauthenticated localhost-only access (fine for dev).
# CRIBL_MCP_API_KEY=
