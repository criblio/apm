    "url": "/api/v1/ai/event",
    "postData": "{\"email\":\"clint@typhoon.org\",\"org\":\"objective-shirley-sho21r7\",\"product\":\"saas-search\",\"environment\":\"saas\",\"uiMode\":\"search\",\"isCloud\":true,\"clientTimestamp\":1776009718581,\"guid\":\"\",\"copyVersion\":1,\"isDev\":true,\"version\":\"4.18.0-dev-nightly.20260412T0356-710d2bce\",\"conversationId\":\"62d4c369-cd71-40df-ae0f-1c1dc15b5af0\",\"eventType\":\"UserQuery\",\"eventClass\":\"submit\",\"surface\":\"searchCopilotInvestigation\",\"userQuery\":\"I'm seeing errors in my payment processing. The \\\"otel\\\" dataset has OpenTelemetry trace data with service.name in resource.attributes. The payment service handles gRPC Charge operations. Can you investigate why the payment service error rate has spiked in the last 15 minutes? Look at the otel dataset for spans where the payment service is failing.\",\"messages\":[{\"id\":\"ff7f5c1d-5010-4134-bc4f-b91a5a70cd4d\",\"role\":\"user\",\"content\":\"I'm seeing errors in my payment processing. The \\\"otel\\\" dataset has OpenTelemetry trace data with service.name in resource.attributes. The payment service handles gRPC Charge operations. Can you investigate why the payment service error rate has spiked in the last 15 minutes? Look at the otel dataset for spans where the payment service is failing.\",\"type\":\"agent\"}]}",
