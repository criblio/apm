ays use this tool instead. Pass structured arguments: incidentMetadata (markdown with title and details table), impactAndScope (string[]), peopleAndRoles ({role, people[]}[]), timelineAndMeasurements ({label, value}[]), communicationsAndChannels ({name, url}[]), summary (narrative paragraph).\",\"schema\":{\"type\":\"object\",\"properties\":{\"incidentMetadata\":{\"type\":\"string\",\"description\":\"Markdown containing ONLY the incident title (h3) and an incident details table (id, title, status, created at, priority, severity). Do NOT include narrative summary, Impact and Scope, Timeline, People and Roles, or Communications here.\"},\"summary\":{\"type\":\"string\",\"description\":\"A short narrative summary paragraph describing the incident. Rendered below the collapsible sections. Do NOT include the title, details table, or structured section content here.\"},\"peopleAndRoles\":{\"type\":\"array\",\"description\":\"People involved in the incident and their roles.\",\"items\":{\"type\":\"object\",\"properties\":{\"role\":{\"type\":\"string\",\"description\":\"The role title (e.g. \\\"Incident Commander\\\").\"},\"people\":{\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"name\":{\"type\":\"string\",\"description\":\"Full name of the person.\"},\"email\":{\"type\":\"string\",\"description\":\"Email address of the person, if available.\"}},\"required\":[\"name\"]},\"description\":\"People assigned to this role. Include email when available from the incident data.\"}},\"required\":[\"role\",\"people\"]}},\"timelineAndMeasurements\":{\"type\":\"array\",\"description\":\"Key timeline events or measurements related to the incident.\",\"items\":{\"type\":\"object\",\"properties\":{\"label\":{\"type\":\"string\",\"description\":\"Label for the entry (e.g. \\\"Time to Detection\\\").\"},\"value\":{\"type\":\"string\",\"description\":\"Value for the entry (e.g. \\\"12 minutes\\\").\"}},\"required\":[\"label\",\"value\"]}},\"impactAndScope\":{\"type\":\"array\",\"description\":\"Bullet points describing the impact and scope of the incident.\",\"items\":{\"type\":\"string\"}},\"communicationsAndChannels\":{\"type\":\"array\",\"description\":\"Communication channels and service links related to the incident.\",\"items\":{\"type\":\"object\",\"properties\":{\"name\":{\"type\":\"string\",\"description\":\"Display name for the link (e.g. \\\"Slack\\\", \\\"Zoom Bridge\\\", \\\"SAAS-19682\\\").\"},\"url\":{\"type\":\"string\",\"description\":\"URL of the communication channel or service.\"}},\"required\":[\"name\",\"url\"]}}}}},{\"id\":\"selectFirehydrantIncident\",\"description\":\"Select a Firehydrant incident to use for the next step. When to run this tool: When you need to view the existing firehydrant incidents.\",\"schema\":{\"type\":\"object\",\"properties\":{\"queries\":{\"type\":\"array\",\"description\":\"Incident search queries to filter Firehydrant incidents. Typically maps to the Firehydrant incident name, description, or summary.\",\"items\":{\"type\":\"string\",\"description\":\"Incident search query to filter Firehydrant incidents. Typically maps to the Firehydrant incident name, description, or summary.\",\"minLength\":0},\"default\":[],\"maxItems\":3,\"minItems\":1},\"incident\":{\"type\":\"string\",\"description\":\"Optional pre-selected Firehydrant incident JSON (for example when the user pasted an incident name/description that was already resolved to an incident).\"}},\"required\":[\"queries\"]}},{\"id\":\"run_search\",\"description\":\"Use this tool to run a search\",\"schema\":{\"type\":\"object\",\"properties\":{\"query\":{\"type\":\"string\",\"description\":\"The KQL query to execute. Should be a valid Cribl search query.\",\"minLength\":1},\"earliest\":{\"type\":[\"string\",\"number\"],\"description\":\"Earliest time for the search. Can be a relative (e.g., \\\"-1h\\\", \\\"-1d\\\") or absolute timestamp as a unix time value in seconds (e.g. 1700511360).\",\"default\":\"-1h\"},\"latest\":{\"type\":[\"string\",\"number\"],\"description\":\"Latest time for the search. Can be relative (e.g., \\\"now\\\", \\\"-5m\\\") or absolute timestamp as a unix time value in seconds (e.g. 1700511360).\",\"default\":\"now\"},\"limit\":{\"type\":\"number\",\"description\":\"Maximum number of events to return.\",\"minimum\":1,\"maximum\":1000,\"default\":10},\"description\":{\"type\":\"string\",\"description\":\"A description of the search that is about to be run\",\"maxLength\":100},\"confirmBeforeRunning\":{\"type\":\"boolean\",\"description\":\"Whether to confirm with the user before running the search.\",\"default\":true}},\"required\":[\"query\",\"description\",\"confirmBeforeRunning\"]}},{\"id\":\"edit_notebook\",\"description\":\"Save the investigation to a notebook with rich context. Provide a descriptive title, a preamble summarizing the investigation, narratives explaining each search, and a conclusion.\",\"schema\":{\"type\":\"object\",\"properties\":{\"title\":{\"type\":\"string\",\"description\":\"A descriptive title for the notebook reflecting the investigation topic.\"},\"preamble\":{\"type\":\"string\",\"description\":\"Markdown section that opens the notebook and sets context for the reader.\"},\"searchNarratives\":{\"type\":\"array\",\"description\":\"Ordered narratives connecting each search to the investigation flow. Each entry pairs a search jobId with an explanatory narrative.\",\"items\":{\"type\":\"object\",\"properties\":{\"jobId\":{\"type\":\"string\",\"description\":\"The jobId of the search this narrative accompanies (from the Executed Searches context).\"},\"narrative\":{\"type\":\"string\",\"description\":\"Markdown explaining the context and reasoning around this search.\"}},\"required\":[\"jobId\",\"narrative\"]}},\"conclusion\":{\"type\":\"string\",\"description\":\"Markdown section that closes the notebook and synthesizes the key takeaways.\"}},\"required\":[\"title\",\"preamble\",\"conclusion\"]}},{\"id\":\"update_context\",\"description\":\"Update the context\",\"schema\":{\"type\":\"object\",\"properties\":{\"key\":{\"type\":\"string\",\"description\":\"The key to update in the context.\"},\"value\":{\"type\":[\"string\",\"number\",\"boolean\",\"object\"],\"description\":\"The value to update the key to.\"}},\"required\":[\"key\",\"value\"]}},{\"id\":\"get_dataset_context\",\"description\":\"Get the context of the dataset. When to run this tool: Use this tool when you need to understand the fields within datasets and their corresponding data types.\",\"schema\":{\"type\":\"object\",\"properties\":{\"datasetIds\":{\"type\":\"array\",\"items\":{\"type\":\"string\"},\"description\":\"Array of dataset IDs to fetch context for\",\"minItems\":1},\"startTime\":{\"type\":\"number\",\"description\":\"The start time of the time range for the dataset context in Unix time milliseconds (defaults to 30 days ago)\"},\"endTime\":{\"type\":\"number\",\"description\":\"The end time of the time range for the dataset context in Unix time milliseconds (defaults to now)\",\"default\":1776009713985}},\"required\":[\"datasetIds\"]}},{\"id\":\"sample_events\",\"description\":\"Use this tool to sample events from datasets (5 raw events each). Limited to 3 datasets maximum.\",\"schema\":{\"type\":\"object\",\"properties\":{\"datasetIds\":{\"type\":\"array\",\"items\":{\"type\":\"string\"},\"description\":\"Array of dataset IDs to query. Maximum 3 datasets will be queried.\",\"minItems\":1,\"maxItems\":3},\"startTime\":{\"type\":\"number\",\"description\":\"The start time of the time range for the sample events in Unix time milliseconds (defaults to 30 days ago)\"},\"endTime\":{\"type\":\"number\",\"description\":\"The end time of the time range for the sample events in Unix time milliseconds (defaults to now)\"},\"updateContextWithSampleEvents\":{\"type\":\"boolean\",\"description\":\"Whether to update the context with sampled events (defaults to true)\",\"default\":true}},\"required\":[\"datasetIds\"]}},{\"id\":\"get_jira_context\",\"description\":\"Get the context of the Jira issue. When to run this tool: Use this tool when you need to incorporate Jira issue context into your response.\",\"schema\":{\"type\":\"object\",\"properties\":{\"jqlQuery\":{\"type\":\"string\",\"description\":\"The JQL query to search for Jira issues\"},\"description\":{\"type\":\"string\",\"description\":\"A description of the Jira issue context that is queried\"}},\"required\":[\"jqlQuery\",\"description\"]}},{\"id\":\"get_bitbucket_context\",\"description\":\"Get Bitbucket PR context. When to run this tool: Use this tool when you need to incorporate Bitbucket PR context into your response.\",\"schema\":{\"type\":\"object\",\"properties\":{\"repository\":{\"type\":\"string\",\"description\":\"The Bitbucket repository to get context for\",\"default\":\"cribl\"},\"workspace\":{\"type\":\"string\",\"description\":\"The Bitbucket workspace to get context for\",\"default\":\"cribl\"},\"pullRequest\":{\"type\":\"string\",\"description\":\"The Bitbucket PR to get context for\"},\"description\":{\"type\":\"string\",\"description\":\"A description of the Bitbucket PR context that is queried\"}},\"required\":[\"pullRequest\",\"repository\",\"description\"]}},{\"id\":\"get_lookup_content_sample\",\"description\":\"Get a sample of the content of a lookup table\",\"schema\":{\"type\":\"object\",\"properties\":{\"lookupId\":{\"type\":\"string\",\"description\":\"The id of the lookup table to get the content of\"}}}},{\"id\":\"present_investigation_summary\",\"description\":\"Present the final investigation summary with structured findings and conclusion. Call this tool ONLY when the investigation is complete and you are ready to present results.\",\"schema\":{\"type\":\"object\",\"properties\":{\"findings\":{\"type\":\"array\",\"description\":\"Investigation findings grouped by evidence category. Each entry has a category name and detailed findings with specific metrics (counts, IPs, timestamps, error codes).\",\"items\":{\"type\":\"object\",\"properties\":{\"category\":{\"type\":\"string\",\"description\":\"Descriptive evidence category name (e.g., \\\"Compromised Pod / Image\\\", \\\"Rogue Cashier Activity\\\", \\\"C2 Exfiltration Channel\\\").\"},\"details\":{\"type\":\"string\",\"description\":\"Markdown-formatted findings for this category. Include specific metrics, field values, counts, and timestamps.\"}},\"required\":[\"category\",\"details\"]},\"minItems\":1},\"conclusion\":{\"type\":\"string\",\"description\":\"Root cause hypothesis or conclusion. 1-3 sentences explaining what happened and why the evidence supports it. If stuck/blocked, explain the blocker.\"}},\"required\":[\"findings\",\"conclusion\"]}}],\"sessionId\":\"62d4c369-cd71-40df-ae0f-1c1dc15b5af0\"}"
